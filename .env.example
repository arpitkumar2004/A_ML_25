# Serving runtime configuration example
# Copy to `.env` and edit paths for your local artifacts.

# Preferred production-style loading: one immutable model bundle.
MODEL_BUNDLE_PATH=
REGISTRY_DIR=experiments/registry

# Core model artifacts
MODELS_DIR=experiments/smoke_check/models
DIM_CACHE=experiments/smoke_check/data/dimred.joblib
OOF_META_PATH=experiments/smoke_check/oof/model_names.joblib
STACKER_PATH=experiments/smoke_check/models/stacker.joblib

# Text feature mode
TEXT_METHOD=tfidf
TFIDF_MAX_FEATURES=1024
TFIDF_VECTORIZER_PATH=experiments/smoke_check/data/tfidf_vectorizer.joblib
NUMERIC_SCALER_PATH=experiments/smoke_check/data/numeric_scaler.joblib
FEATURE_SELECTOR_PATH=experiments/smoke_check/data/feature_selector.joblib
# auto | true | false
SELECTOR_ENABLED=auto

# Image embedding runtime
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
IMAGE_BATCH_SIZE=16

# API hardening
# Leave blank to disable API-key auth for local development.
API_KEY=
MAX_PREDICT_RECORDS=200
SERVICE_BASE_URL=
CANARY_SERVICE_BASE_URL=
SERVICE_TIMEOUT_SECONDS=5

# Canary routing (optional)
CANARY_BUNDLE_PATH=
CANARY_RUN_ID=
CANARY_MODELS_DIR=
CANARY_PERCENT=0
CANARY_COMPARE=false

# Optional HF auth token aliases
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
HF_SPACE_REPO_ID=arpitkumariitkgp/aml25
HF_SPACE_TOKEN=

# Durable bundle archive storage via GitHub Releases
BUNDLE_RELEASE_TAG_PREFIX=bundle-archive

# DVC / DagsHub sync credentials (optional, for dvc push/pull to DagsHub storage)
# If AWS_* are not set, scripts/dvc_with_env.ps1 maps DAGSHUB_USERNAME + DAGSHUB_TOKEN.
DAGSHUB_USERNAME=
DAGSHUB_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
